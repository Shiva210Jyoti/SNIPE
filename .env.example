# Copy to .env and adjust for your machine
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/snipeurl
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
CACHE_TTL_SECONDS=3600
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLICK_TOPIC=url-clicks
KAFKA_CONSUMER_GROUP=snipurl-click-consumers
KAFKA_ENABLED=true
BASE_URL=http://localhost:8000
APP_NAME=SnipURL
DEBUG=true
